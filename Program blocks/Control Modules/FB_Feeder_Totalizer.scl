FUNCTION_BLOCK "FB_Feeder_Totalizer"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 1.0
   VAR_INPUT 
      i_Clear_Totalizer : Bool; // Lệnh xoá bộ cộng dồn về 0
      i_Target_Weight : Real; // Khối lượng mục tiêu của mẻ (kg)
      i_Raw_FlowRate : Real; // Lưu lượng thô chưa qua lọc (kg/h)
      i_CycleTime_sec : Real; // Chu kỳ quét thực thi OB30 (giây)
      i_AutoMode : Bool; // Cờ báo chế độ Tự động
      i_Running : Bool; // Cờ báo trạng thái biến tần đang chạy
      i_TestMode : Bool; // Kích hoạt chế độ chạy thử
      i_TestTarget : Real; // Khối lượng đích chạy thử (kg)
   END_VAR

   VAR_OUTPUT 
      o_Totalized_Weight : Real; // Khối lượng cộng dồn ngõ ra (kg)
      o_TestTotal : Real; // Khối lượng chạy thử (kg)
      o_Done : Bool; // Cờ báo hoàn thành mẻ cân
      o_Dribble_Active : Bool; // Cờ báo đang trong giai đoạn chạy chậm (Dribble)
   END_VAR

   VAR_IN_OUT 
      io_Config : "UDT_Feeder_Config";
   END_VAR

   VAR 
      stat_Done_Latch : Bool; // Biến nhớ chốt trạng thái hoàn thành mẻ
      stat_Last_Target : Real; // Khối lượng mục tiêu của mẻ trước (dùng để Auto-Learning)
      stat_Prev_Running : Bool; // Trạng thái chạy của chu kỳ trước (Bắt sườn xuống)
      stat_Prev_TestMode : Bool; // Lưu trạng thái TestMode chu kỳ trước để bắt sườn xuống
   END_VAR
   VAR RETAIN
      stat_Totalized_Weight : LReal; // Biến cộng dồn nội bộ (LReal 64-bit chống tràn sai số)
      stat_TestTotal : LReal; // Biến cộng dồn chạy thử (LReal 64-bit)
   END_VAR

   VAR_TEMP 
      temp_LowFlow_Cutoff : Real; // Ngưỡng cắt lưu lượng thấp (chống trôi điểm 0)
      temp_Remaining_kg : Real; // Khối lượng còn lại cần cân (kg)
      temp_Dribble_Threshold : Real; // Ngưỡng bắt đầu chạy chậm (kg)
   END_VAR


BEGIN
	// Reset / Clear Data
	IF #i_Clear_Totalizer THEN
	    // Nếu đang chạy thử: Chỉ xoá số tổng chạy thử, giữ lại số tổng thật
	    IF #i_TestMode THEN
	        #stat_TestTotal := 0.0;
	    ELSE
	        // Nếu chạy thật hoặc lệnh xoá tổng quát: Xoá cả hai
	        #stat_Totalized_Weight := 0.0;
	        #stat_TestTotal := 0.0;
	    END_IF;
	    
	    #stat_Done_Latch := FALSE; 
	    #o_Done := FALSE;
	    #o_Dribble_Active := FALSE;
	    #stat_Last_Target := 0.0;
	    #stat_Prev_Running := FALSE;
	END_IF;
	
	// LOW FLOW CUTOFF: Ngưỡng cắt lưu lượng tối thiểu chống trôi Totalizer
	IF #io_Config.MaxFlowRate > 0.1 THEN
	    #temp_LowFlow_Cutoff := #io_Config.MaxFlowRate * 0.002; // Giảm xuống 0.2% thay vì 1%
	ELSE
	    #temp_LowFlow_Cutoff := 0.1; // Fallback thấp hơn
	END_IF;
	
	// Điều kiện cộng dồn: Không đang xóa AND (Lưu lượng > Ngưỡng HOẶC Đang chạy thực tế)
	IF NOT #i_Clear_Totalizer AND (#i_Raw_FlowRate > 0.001) AND (#i_Raw_FlowRate > #temp_LowFlow_Cutoff OR #i_Running OR #i_TestMode) THEN
	    // Khối lượng đi được trong chu kỳ này (Tính toán bằng LREAL để đảm bảo độ chính xác tuyệt đối)
	    #stat_TestTotal := #stat_TestTotal; // Dummy line for logic separation
	    
	    // Cộng dồn vào Khối lượng tổng (Totalized Weight) luôn bất kể chế độ nào
	    #stat_Totalized_Weight := #stat_Totalized_Weight + (REAL_TO_LREAL(#i_Raw_FlowRate) * REAL_TO_LREAL(#i_CycleTime_sec) / 3600.0);

	    // Phân nhánh cộng dồn: Chạy thử hoặc Chạy thật
	    IF #i_TestMode THEN
	        #stat_TestTotal := #stat_TestTotal + (REAL_TO_LREAL(#i_Raw_FlowRate) * REAL_TO_LREAL(#i_CycleTime_sec) / 3600.0);
	        // Chạy thử chỉ cộng dồn, không bật cờ Done báo hoàn thành mẻ. FB_WeighFeeder sẽ tự động ngắt theo điều kiện.
	        
	        // THÊM: DRIBBLE FEED (Chạy chậm lại khi gần đích) cho chế độ chạy thử
	        IF (#i_TestTarget > 0.0) THEN
	            #temp_Remaining_kg := #i_TestTarget - LREAL_TO_REAL(#stat_TestTotal);
	            #temp_Dribble_Threshold := #i_TestTarget * (#io_Config.Dribble_Pct / 100.0);
	            
	            // Phase 1: Gần đạt target -> Chuyển sang Dribble (giảm tốc)
	            IF (#temp_Remaining_kg > 0.0) AND (#temp_Remaining_kg <= #temp_Dribble_Threshold) THEN
	                #o_Dribble_Active := TRUE;
	            ELSE
	                #o_Dribble_Active := FALSE;
	            END_IF;
	        END_IF;
	    ELSE
	        // DRIBBLE FEED + IN-FLIGHT COMPENSATION (Chỉ áp dụng khi chạy thật)
	        IF (#i_Target_Weight > 0.0) THEN
	            #temp_Remaining_kg := #i_Target_Weight - LREAL_TO_REAL(#stat_Totalized_Weight);
	            #temp_Dribble_Threshold := #i_Target_Weight * (#io_Config.Dribble_Pct / 100.0);
	            
	            // Phase 1: Gần đạt target -> Chuyển sang Dribble (giảm tốc)
	            IF (#temp_Remaining_kg > 0.0) AND (#temp_Remaining_kg <= #temp_Dribble_Threshold) THEN
	                #o_Dribble_Active := TRUE;
	            ELSE
	                #o_Dribble_Active := FALSE;
	            END_IF;
	            
	            // Phase 2: Cut-off sớm (In-Flight Compensation)
	            IF (#i_Target_Weight > 0.1) THEN
	                IF #stat_Totalized_Weight >= (#i_Target_Weight - #io_Config.InFlight_kg) THEN
	                    #stat_Done_Latch := TRUE;
	                    #stat_Last_Target := #i_Target_Weight; // Lưu lại target để mẻ sau học tập
	                END_IF;
	            END_IF;
	        END_IF;
	    END_IF;
	END_IF; 
	 
	#o_Done := #stat_Done_Latch;
	#o_Totalized_Weight := LREAL_TO_REAL(#stat_Totalized_Weight);
	#o_TestTotal := LREAL_TO_REAL(#stat_TestTotal);
	
	// =============================================================
	// AUTO IN-FLIGHT LEARNING (TỰ ĐỘNG BÙ SAI SỐ)
	// =============================================================
	IF NOT #i_Running AND #stat_Prev_Running AND #o_Done AND #i_AutoMode AND NOT #i_TestMode THEN
	    #temp_Remaining_kg := LREAL_TO_REAL(#stat_Totalized_Weight) - #stat_Last_Target;
	    
	    // TẠM TẮT: Để người dùng tự chỉnh In-Flight bằng tay
	    // #io_Config.InFlight_kg := #io_Config.InFlight_kg + (#temp_Remaining_kg * 0.5);
	    
	    IF #io_Config.InFlight_kg < 0.0 THEN
	        #io_Config.InFlight_kg := 0.0;
	    ELSIF #io_Config.InFlight_kg > 5.0 THEN
	        #io_Config.InFlight_kg := 5.0;
	    END_IF;
	END_IF;
	
	#stat_Prev_Running := #i_Running;
	
	// Tự động xoá trạng thái Done khi thoát chế độ Chạy thử (để sẵn sàng cho mẻ thật)
	IF #stat_Prev_TestMode AND NOT #i_TestMode THEN
	    #stat_Done_Latch := FALSE;
	END_IF;
	#stat_Prev_TestMode := #i_TestMode;

END_FUNCTION_BLOCK
